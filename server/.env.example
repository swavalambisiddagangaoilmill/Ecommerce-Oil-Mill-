NODE_ENV=production
PORT=5000
BACKEND_PUBLIC_URL=https://api.swavalambisiddagangaoilmill.com
CLIENT_URL=https://swavalambisiddagangaoilmill.com
CLIENT_URLS=https://swavalambisiddagangaoilmill.com,https://www.swavalambisiddagangaoilmill.com
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/<database>?retryWrites=true&w=majority
JWT_SECRET=<strong-64-character-random-secret>
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=15d
GOOGLE_CLIENT_ID=<google-oauth-client-id>.apps.googleusercontent.com
TURNSTILE_SECRET_KEY=<cloudflare-turnstile-secret-key>
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=<razorpay-live-secret>
RAZORPAY_WEBHOOK_SECRET=<razorpay-webhook-secret>
CLOUDINARY_NAME=<cloudinary-cloud-name>
CLOUDINARY_KEY=<cloudinary-api-key>
CLOUDINARY_SECRET=<cloudinary-api-secret>
EMAIL_PROVIDER=resend
RESEND_API_KEY=<resend-api-key>
EMAIL_FROM=Swavalambi Siddaganga Oil Mill <orders@swavalambisiddagangaoilmill.com>
EMAIL_REPLY_TO=support@swavalambisiddagangaoilmill.com
CONTACT_TO_EMAIL=support@swavalambisiddagangaoilmill.com
SHIPROCKET_MOCK=false
SHIPROCKET_EMAIL=<shiprocket-login-email>
SHIPROCKET_PASSWORD=<shiprocket-password>
SHIPROCKET_PICKUP_LOCATION=<pickup-location-name>
SHIPROCKET_PICKUP_POSTCODE=<pickup-postcode>
SHIPROCKET_WEBHOOK_SECRET=<shiprocket-webhook-secret>
SHIPROCKET_DEFAULT_WEIGHT_KG=1
SHIPROCKET_DEFAULT_LENGTH_CM=20
SHIPROCKET_DEFAULT_BREADTH_CM=15
SHIPROCKET_DEFAULT_HEIGHT_CM=10